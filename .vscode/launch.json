{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run CodeGuardian Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--disable-extensions",
        "--disable-workspace-trust",
        "--skip-welcome",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [],
      "sourceMaps": false
    }
  ]
}
